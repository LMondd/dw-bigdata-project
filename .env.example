# Copy to .env and fill in real values. NEVER commit .env

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=ec2-xx-xx-xx-xx.compute-1.amazonaws.com:9092
KAFKA_CLIENT_ID=dw-bigdata-local

# --- AWS ---
AWS_REGION=us-east-1
S3_BUCKET=dw-bigdata-6538140221
DYNAMODB_TABLE=sensor-aggregates

# --- Air4Thai ---
AIR4THAI_BASE_URL=http://air4thai.pcd.go.th/services/getNewAQI_JSON.php

# --- OpenWeather ---
OPENWEATHER_API_KEY=your_api_key_here
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# --- Logging ---
LOG_LEVEL=INFO
